[gd_scene load_steps=4 format=3 uid="uid://mainmenusstandalone"]

[ext_resource type="Script" path="res://Scenes/Main/MainMenu.gd" id="1_menu"]
[ext_resource type="Theme" uid="uid://maintheme" path="res://Resources/Theme/main_theme.tres" id="2_theme"]
[ext_resource type="Texture2D" path="res://Assets/Icons/logo.png" id="3_logo"]

[node name="MainMenu" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
theme = ExtResource("2_theme")
script = ExtResource("1_menu")

[node name="Background" type="ColorRect" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
color = Color(0.05, 0.05, 0.1, 1)

[node name="MarginContainer" type="MarginContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
theme_override_constants/margin_left = 40
theme_override_constants/margin_top = 100
theme_override_constants/margin_right = 40
theme_override_constants/margin_bottom = 100

[node name="VBoxContainer" type="VBoxContainer" parent="MarginContainer"]
layout_mode = 2
theme_override_constants/separation = 30
alignment = 1

[node name="TitleLabel" type="Label" parent="MarginContainer/VBoxContainer"]
layout_mode = 2
theme_override_font_sizes/font_size = 48
text = "WATERNET"
horizontal_alignment = 1

[node name="SubtitleLabel" type="Label" parent="MarginContainer/VBoxContainer"]
layout_mode = 2
theme_override_font_sizes/font_size = 24
text = "Connection Puzzle"
horizontal_alignment = 1

[node name="LogoRect" type="TextureRect" parent="MarginContainer/VBoxContainer"]
custom_minimum_size = Vector2(160, 160)
layout_mode = 2
size_flags_horizontal = 4
texture = ExtResource("3_logo")
expand_mode = 1
stretch_mode = 5

[node name="PlayBtn" type="Button" parent="MarginContainer/VBoxContainer"]
custom_minimum_size = Vector2(0, 70)
layout_mode = 2
theme_override_font_sizes/font_size = 28
text = "PLAY"

[node name="LeaderboardBtn" type="Button" parent="MarginContainer/VBoxContainer"]
custom_minimum_size = Vector2(0, 60)
layout_mode = 2
theme_override_font_sizes/font_size = 20
text = "LEADERBOARD & PROFILE"

[node name="HBoxVolume" type="HBoxContainer" parent="MarginContainer/VBoxContainer"]
layout_mode = 2
alignment = 1

[node name="MuteBtn" type="Button" parent="MarginContainer/VBoxContainer/HBoxVolume"]
custom_minimum_size = Vector2(250, 50)
layout_mode = 2
text = "VOLUME: ON"

[node name="CopyrightLabel" type="Label" parent="MarginContainer/VBoxContainer"]
layout_mode = 2
theme_override_constants/outline_size = 0
theme_override_font_sizes/font_size = 14
text = "© 2026 Shinokute Studio. All Rights Reserved."
horizontal_alignment = 1

[connection signal="pressed" from="MarginContainer/VBoxContainer/PlayBtn" to="." method="_on_play_btn_pressed"]
[connection signal="pressed" from="MarginContainer/VBoxContainer/LeaderboardBtn" to="." method="_on_leaderboard_btn_pressed"]
[connection signal="pressed" from="MarginContainer/VBoxContainer/HBoxVolume/MuteBtn" to="." method="_on_mute_btn_pressed"]
