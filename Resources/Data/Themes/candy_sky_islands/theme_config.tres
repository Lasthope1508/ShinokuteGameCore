[sub_resource type="Resource" id="Role_player_model"]
script = ExtResource("2_role")
role_key = "player.model"
legacy_path = "res://models/character.glb"
reference_path = "res://assets/themes/candy_sky_islands/models/character_chr077_skeleton_mage.glb"
replacement_path = "res://objects/character.tscn"
mode = "replacement"
proof_path = "res://docs/screenshots/candy_sky_islands_player_glb_replacement.png"
notes = "Legacy character GLB first replaced by Candy marshmallow GLB, then Shinokute human GLB, now by CHR077 Skeleton Mage GLB from KayKit CC0 in objects/character.tscn; CHR077 raw size is scaled through CHR077SkeletonMageSlot at 0.5 to meet player.visual_target_height 1.30 u and allowed range 1.10..1.35 u; player scene preserves controller, collider, animation target, idle/walk/jump names, adds future run, uses 1/60s animation step, and preserves movement, jump, footsteps, and in-place fall retry behavior."

