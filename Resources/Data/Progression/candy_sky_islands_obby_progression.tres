[resource]
script = ExtResource("1_config")
game_family = "3d_obby"
completion_policy = "next_loop"
required_difficulty_keys = Array[String](["falling_platform_acceleration", "falling_platform_trigger_delay"])
difficulty_sort_directions = {"falling_platform_acceleration": "ASCENDING", "falling_platform_trigger_delay": "DESCENDING"}
required_layout_keys = Array[String](["route_length", "platform_count", "verticality", "gap_distance", "hazard_count", "route_width"])
layout_sort_directions = {"gap_distance": "ASCENDING", "hazard_count": "ASCENDING", "platform_count": "ASCENDING", "route_length": "ASCENDING", "route_width": "ASCENDING", "verticality": "ASCENDING"}
level_catalog = Array[Resource]([SubResource("Level_lollipop_intro"), SubResource("Level_marshmallow_steps"), SubResource("Level_candy_drop")])
