failure_policy = {"type": "retry_current", "fall_reset_y": -10.0}
layout_profile = {"gap_distance": 3.0, "hazard_count": 1, "platform_count": 5, "route_length": 18.0, "verticality": 1.0}
stage_segments = [{"platform": "large", "position": Vector3(0, 0, 0), "role": "start"}, {"coin": true, "platform": "medium", "position": Vector3(-4, 0.25, 2), "role": "platform"}, {"coin": true, "platform": "falling", "position": Vector3(-8, 0.45, 4), "role": "hazard"}, {"coin": true, "platform": "small", "position": Vector3(-12, 0.75, 2), "role": "platform"}, {"goal_offset": Vector3(0, 1.2, 0), "platform": "medium", "position": Vector3(-16, 1, 0), "role": "goal"}]
