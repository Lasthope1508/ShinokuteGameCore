[resource]
script = ExtResource("1_config")
game_family = "3d_obby"
completion_policy = "next_loop"
required_difficulty_keys = Array[String](["falling_platform_acceleration", "falling_platform_trigger_delay"])
difficulty_sort_directions = {"falling_platform_acceleration": "ASCENDING", "falling_platform_trigger_delay": "DESCENDING"}
required_layout_keys = Array[String](["route_length", "platform_count", "verticality", "gap_distance", "hazard_count", "route_width"])
layout_sort_directions = {"gap_distance": "ASCENDING", "hazard_count": "ASCENDING", "platform_count": "ASCENDING", "route_length": "ASCENDING", "route_width": "ASCENDING", "verticality": "ASCENDING"}
dynamic_progression_profile = {"difficulty_curves": {"falling_platform_acceleration": {"base": 24.0, "max": 72.0, "mode": "sqrt", "per_level": 5.2}, "falling_platform_trigger_delay": {"base": 0.2, "min": 0.2, "mode": "linear", "per_level": -0.002}}, "display_name_format": "Level %d", "layout_curves": {"descent_ratio": {"base": 0.1, "max": 0.35, "mode": "log", "per_level": 0.06}, "gap_distance": {"base": 3.0, "jump_cap_margin": 0.12, "max": 3.0, "max_from_jump_cap": true, "mode": "log", "per_level": 0.05}, "hazard_count": {"base": 5.0, "mode": "sqrt", "per_level": 1.6, "round": "floor"}, "height_wave_amplitude": {"base": 0.35, "max": 1.2, "mode": "sqrt", "per_level": 0.18}, "height_wave_cycles": {"base": 1.0, "max": 4.0, "mode": "log", "per_level": 0.45}, "max_step_distance": {"base": 3.0, "mode": "linear", "per_level": 0.0}, "max_step_height": {"base": 0.38, "mode": "linear", "per_level": 0.0}, "platform_count": {"base": 24.0, "mode": "linear", "per_level": 1.55, "round": "ceil"}, "route_length": {"base": 64.0, "mode": "linear", "per_level": 4.2}, "route_width": {"base": 18.0, "mode": "sqrt", "per_level": 1.7}, "turn_cycles": {"base": 2.2, "max": 7.0, "mode": "log", "per_level": 0.75}, "verticality": {"base": 6.5, "mode": "sqrt", "per_level": 1.15}}, "level_id_format": "obby_%03d_dynamic", "layout_defaults": {"route_generator": "shinokute_3d_obby_curve_v1"}, "platform_mix": [{"platform": "small", "weight": 6}, {"platform": "medium", "weight": 3}, {"platform": "small", "weight": 4}, {"platform": "medium", "weight": 2}], "platform_radii": {"falling": 1.1, "large": 2.5, "medium": 1.5, "small": 1.0}, "route_generator": "shinokute_3d_obby_curve_v1", "route_shape": {"max_lateral_step_ratio": 0.72, "position_jitter": 0.18, "recovery_interval": 5, "width_overshoot_factor": 0.66}, "seed_base": 9100, "seed_stride": 131, "start_level_number": 4, "template_level_index": 2}
