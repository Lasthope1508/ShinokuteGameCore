; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="collection"
run/main_scene="res://Main.tscn"
config/features=PackedStringArray("4.3", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

McpInteractionServer="*res://Scripts/mcp_interaction_server.gd"
AdManager="*res://Resources/Globals/AdManager.gd"
SaveManager="*res://Resources/Globals/SaveManager.gd"
GameState="*res://Resources/Globals/GameState.gd"
ThemeManager="*res://Resources/Globals/ThemeManager.gd"
AudioManager="*res://Resources/Globals/AudioManager.gd"
SceneRouter="*res://Resources/Globals/SceneRouter.gd"
LeaderboardManager="*res://Scripts/LeaderboardManager.gd"

[display]

window/size/viewport_width=1366
window/size/viewport_height=768
window/stretch/mode="canvas_items"

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
